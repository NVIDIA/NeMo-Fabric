{
  "$defs": {
    "AdapterKind": {
      "description": "Adapter implementation kind.",
      "oneOf": [
        {
          "const": "process",
          "description": "Launch and supervise a CLI process.",
          "type": "string"
        },
        {
          "const": "http",
          "description": "Connect to a service or HTTP-backed harness.",
          "type": "string"
        },
        {
          "const": "python",
          "description": "Call a Python SDK/plugin adapter.",
          "type": "string"
        },
        {
          "const": "native_plugin",
          "description": "Delegate to a harness-native plugin package.",
          "type": "string"
        }
      ]
    },
    "ArtifactManifest": {
      "description": "Manifest of run artifacts.",
      "properties": {
        "artifacts": {
          "description": "Artifact entries.",
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "type": "array"
        },
        "root": {
          "description": "Artifact root directory.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "ArtifactRef": {
      "description": "Reference to one artifact.",
      "properties": {
        "kind": {
          "description": "Artifact kind.",
          "type": "string"
        },
        "media_type": {
          "description": "Optional media type.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Logical artifact name.",
          "type": "string"
        },
        "path": {
          "description": "Artifact path.",
          "type": "string"
        }
      },
      "required": [
        "name",
        "kind",
        "path"
      ],
      "type": "object"
    },
    "ErrorInfo": {
      "description": "Normalized error metadata.",
      "properties": {
        "code": {
          "description": "Stable error code.",
          "type": "string"
        },
        "message": {
          "description": "Human-readable error message.",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "description": "Adapter or runtime metadata useful for diagnostics.",
          "type": "object"
        },
        "retryable": {
          "default": false,
          "description": "Whether Fabric considers this failure safe for a consumer-level retry.",
          "type": "boolean"
        },
        "stage": {
          "$ref": "#/$defs/ErrorStage",
          "description": "Fabric lifecycle stage where the failure surfaced."
        }
      },
      "required": [
        "stage",
        "code",
        "message"
      ],
      "type": "object"
    },
    "ErrorStage": {
      "description": "Fabric lifecycle stage associated with an error.",
      "oneOf": [
        {
          "const": "config",
          "description": "Configuration or profile loading failed.",
          "type": "string"
        },
        {
          "const": "plan",
          "description": "Effective config planning failed.",
          "type": "string"
        },
        {
          "const": "prepare",
          "description": "Environment preparation failed.",
          "type": "string"
        },
        {
          "const": "start",
          "description": "Runtime start/connect failed.",
          "type": "string"
        },
        {
          "const": "invoke",
          "description": "Runtime invocation failed.",
          "type": "string"
        },
        {
          "const": "stop",
          "description": "Runtime stop/detach failed.",
          "type": "string"
        },
        {
          "const": "release",
          "description": "Environment release failed.",
          "type": "string"
        },
        {
          "const": "artifact",
          "description": "Artifact collection or writing failed.",
          "type": "string"
        }
      ]
    },
    "FabricEvent": {
      "description": "Fabric lifecycle or progress event.",
      "properties": {
        "event_id": {
          "description": "Event id.",
          "type": "string"
        },
        "kind": {
          "description": "Event kind.",
          "type": "string"
        },
        "message": {
          "description": "Event message.",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "description": "Event metadata.",
          "type": "object"
        },
        "timestamp_millis": {
          "description": "Unix timestamp in milliseconds.",
          "format": "uint128",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "event_id",
        "timestamp_millis",
        "kind",
        "message"
      ],
      "type": "object"
    },
    "RunStatus": {
      "description": "Runtime completion status.",
      "oneOf": [
        {
          "const": "succeeded",
          "description": "The harness completed successfully.",
          "type": "string"
        },
        {
          "const": "failed",
          "description": "The harness completed with a non-zero status.",
          "type": "string"
        },
        {
          "const": "cancelled",
          "description": "The invocation or runtime was cancelled.",
          "type": "string"
        }
      ]
    },
    "TelemetryRef": {
      "description": "Reference to telemetry emitted by Relay or another configured telemetry path.",
      "properties": {
        "metadata": {
          "additionalProperties": true,
          "description": "Telemetry metadata.",
          "type": "object"
        },
        "relay_enabled": {
          "description": "Whether Relay was enabled for this run.",
          "type": "boolean"
        }
      },
      "required": [
        "relay_enabled"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Result from a Fabric-managed harness invocation.",
  "properties": {
    "adapter_id": {
      "description": "Adapter implementation id when an adapter descriptor was resolved.",
      "type": [
        "string",
        "null"
      ]
    },
    "adapter_kind": {
      "$ref": "#/$defs/AdapterKind",
      "description": "Adapter used for this run."
    },
    "agent_name": {
      "description": "Stable agent name.",
      "type": "string"
    },
    "artifacts": {
      "$ref": "#/$defs/ArtifactManifest",
      "default": {},
      "description": "Artifacts produced or collected by this run."
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ErrorInfo"
        },
        {
          "type": "null"
        }
      ],
      "description": "Error metadata when applicable."
    },
    "events": {
      "description": "Fabric lifecycle/progress events emitted during the run.",
      "items": {
        "$ref": "#/$defs/FabricEvent"
      },
      "type": "array"
    },
    "harness_type": {
      "description": "Harness type used for this run.",
      "type": "string"
    },
    "invocation_id": {
      "description": "Invocation handle id.",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "description": "Adapter-specific metadata.",
      "type": "object"
    },
    "output": {
      "default": null,
      "description": "Primary output."
    },
    "profile": {
      "description": "Selected profile name when loaded through an agent manifest.",
      "type": [
        "string",
        "null"
      ]
    },
    "request_id": {
      "description": "Request id.",
      "type": "string"
    },
    "runtime_id": {
      "description": "Runtime handle id.",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/RunStatus",
      "description": "Runtime status."
    },
    "telemetry": {
      "anyOf": [
        {
          "$ref": "#/$defs/TelemetryRef"
        },
        {
          "type": "null"
        }
      ],
      "description": "Telemetry reference when available."
    }
  },
  "required": [
    "agent_name",
    "harness_type",
    "adapter_kind",
    "runtime_id",
    "invocation_id",
    "request_id",
    "status"
  ],
  "title": "RunResult",
  "type": "object"
}