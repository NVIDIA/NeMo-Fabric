    "telemetry_plan": {
      "anyOf": [
        {
          "$ref": "#/$defs/TelemetryPlan"
        },
        {
          "type": "null"
        }
      ],
      "description": "Resolved telemetry pass-through plan."
    }
  },
  "required": [
    "effective_config",
    "agent_name",
    "capabilities",
    "base_dir",
    "config"
