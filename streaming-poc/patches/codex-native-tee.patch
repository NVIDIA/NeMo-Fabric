+async def _poc_run_with_tee(handle: Any) -> Any:
+    """POC-only: run the turn while teeing each native notification before Relay."""
+    from openai_codex._run import _collect_async_turn_result
+
+    stream = handle.stream()
+
+    async def _teed() -> Any:
+        async for event in stream:
+            try:
+                import sys as _sys
+
+                _sys.path.insert(0, os.environ.get("POC_RECORDER_DIR", ""))
+                from native_recorder import record as _record
+
+                payload_obj = getattr(event, "payload", None)
+                if hasattr(payload_obj, "model_dump"):
+                    native = payload_obj.model_dump(mode="json")
+                elif hasattr(payload_obj, "__dict__"):
+                    native = dict(payload_obj.__dict__)
+                else:
+                    native = payload_obj
+                _record(
+                    "codex-sdk",
+                    getattr(event, "method", "event"),
+                    {"method": getattr(event, "method", None), "payload": native},
+                )
+            except Exception:
+                pass
+            yield event
+
+    try:
+        return await _collect_async_turn_result(_teed(), turn_id=handle.id)
+    finally:
+        await stream.aclose()
+
+
 async def _invoke_thread(
