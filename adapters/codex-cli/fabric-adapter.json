{
  "contract_version": "fabric.adapter/v1alpha1",
  "adapter_id": "nvidia.fabric.codex.cli",
  "harness": "codex",
  "adapter_kind": "python",
  "runner": {
    "module": "nemo_fabric_adapters.codex_cli.adapter",
    "callable": "run_codex"
  },
  "requirements": {
    "binaries": ["codex"]
  },
  "config": {
    "accepts": ["models", "telemetry"]
  },
  "telemetry": {
    "providers": {
      "relay": {
        "outputs": ["atif", "otel", "openinference"],
        "integration_modes": ["hooks", "gateway"]
      },
      "native": {
        "outputs": ["otel"]
      }
    }
  }
}
