{
  "contract_version": "fabric.adapter/v1alpha1",
  "adapter_id": "nvidia.fabric.langchain.deepagents",
  "harness": "deepagents",
  "adapter_kind": "python",
  "runner": {
    "module": "nemo_fabric_adapters.deepagents.adapter",
    "callable": "run"
  },
  "requirements": {},
  "config": {
    "accepts": ["models", "tools", "tools.blocked", "mcp", "skills", "telemetry"]
  },
  "telemetry": {
    "providers": {
      "relay": {
        "outputs": ["atif", "otel", "openinference"]
      },
      "native": {
        "outputs": ["otel", "openinference"]
      }
    }
  },
  "runtime": {
    "local_host": {}
  }
}
