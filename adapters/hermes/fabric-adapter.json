{
  "contract_version": "fabric.adapter/v1alpha1",
  "adapter_id": "nvidia.fabric.hermes",
  "harness": "hermes",
  "adapter_kind": "python",
  "runner": {
    "module": "nemo_fabric_adapters.hermes.adapter"
  },
  "requirements": {},
  "config": {
    "accepts": [
      "models",
      "models.base_url",
      "models.temperature",
      "system_prompt",
      "max_turns",
      "tools.toolsets.enabled",
      "tools.toolsets.blocked",
      "mcp",
      "skills"
    ]
  },
  "telemetry": {
    "providers": {
      "relay": {
        "outputs": [
          "atif",
          "otel",
          "openinference"
        ]
      }
    }
  }
}
