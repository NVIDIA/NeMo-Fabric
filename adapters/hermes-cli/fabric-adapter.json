{
  "adapter_id": "nvidia.fabric.hermes.cli",
  "harness_type": "hermes",
  "adapter_kind": "process",
  "runner": {
    "command": "python3",
    "script": "src/nemo_fabric_adapters/hermes_cli/adapter.py",
    "stdin_payload": "fabric_request"
  },
  "requirements": {
    "env": ["NVIDIA_API_KEY"],
    "binaries": ["hermes"]
  },
  "config": {
    "accepts": ["tools", "mcp", "skills", "telemetry"]
  },
  "telemetry": {
    "supports": ["relay", "atif", "otel", "openinference"]
  }
}
