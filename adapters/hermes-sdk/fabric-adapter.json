{
  "adapter_id": "nvidia.fabric.hermes.sdk",
  "adapter_kind": "python",
  "runner": {
    "module": "nemo_fabric_adapters.hermes_sdk.adapter",
    "callable": "run",
    "script": "src/nemo_fabric_adapters/hermes_sdk/adapter.py"
  },
  "requirements": {
    "env": [
      "NVIDIA_API_KEY"
    ]
  },
  "config": {
    "accepts": [
      "tools",
      "mcp",
      "skills",
      "telemetry"
    ]
  },
  "telemetry": {
    "supports": [
      "relay",
      "atif",
      "otel",
      "openinference"
    ]
  }
}
