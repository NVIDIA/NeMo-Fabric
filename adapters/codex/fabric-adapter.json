{
  "contract_version": "fabric.adapter/v1alpha1",
  "adapter_id": "nvidia.fabric.codex",
  "harness": "codex",
  "adapter_kind": "python",
  "runner": {
    "module": "nemo_fabric_adapters.codex.adapter",
    "callable": "run"
  },
  "config": {
    "accepts": ["models", "telemetry"]
  },
  "execution": {
    "lifecycle_contract_version": "fabric.adapter.lifecycle/v1alpha1",
    "strategies": ["process_per_invocation", "persistent_local_host"]
  },
  "telemetry": {
    "providers": {
      "relay": {
        "outputs": ["atif", "otel", "openinference"],
        "integration_modes": ["hooks", "gateway"]
      },
      "native": {
        "outputs": ["otel"]
      }
    }
  }
}
