{
  "contract_version": "fabric.adapter/v1alpha1",
  "adapter_id": "nvidia.fabric.codex",
  "harness": "codex",
  "adapter_kind": "python",
  "runner": {
    "module": "nemo_fabric_adapters.codex.adapter",
    "callable": "run"
  },
  "config": {
    "accepts": ["models", "telemetry"]
  },
  "models": {
    "roles": ["default"],
    "protocols": {
      "openai-responses": {
        "providers": ["openai"],
        "custom_endpoints": false
      }
    }
  },
  "telemetry": {
    "providers": {
      "relay": {
        "outputs": ["atif", "otel", "openinference"],
        "integration_modes": ["hooks", "gateway"]
      },
      "native": {
        "outputs": ["otel"]
      }
    }
  }
}
