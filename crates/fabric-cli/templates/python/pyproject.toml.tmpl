[build-system]
requires = ["setuptools>=77"]
build-backend = "setuptools.build_meta"

[project]
name = "{{PACKAGE}}-python"
version = "0.1.0"
requires-python = ">=3.11"
dependencies = ["nemo-fabric-runtime"]

[tool.setuptools]
py-modules = ["main"]
