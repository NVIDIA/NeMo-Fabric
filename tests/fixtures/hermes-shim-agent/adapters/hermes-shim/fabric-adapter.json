{
  "contract_version": "fabric.adapter/v1alpha1",
  "adapter_id": "test.fabric.hermes_shim",
  "harness": "hermes",
  "adapter_kind": "python",
  "runner": {
    "module": "nemo_fabric_test_adapters.hermes_shim.adapter",
    "cwd": ".",
    "env": {
      "PYTHONPATH": "adapters/hermes-shim/src"
    }
  },
  "requirements": {
    "binaries": [
      "python3"
    ]
  },
  "config": {
    "accepts": [
      "models",
      "models.temperature",
      "mcp",
      "skills",
      "telemetry"
    ]
  },
  "telemetry": {
    "providers": {
      "relay": {}
    }
  }
}
